{
  "name": "orch-agents",
  "version": "0.1.0.1",
  "description": "Autonomous Development Agency System - orchestrates AI agent swarms for software development workflows",
  "type": "commonjs",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "default": "./dist/lib/index.js"
    },
    "./compact": {
      "types": "./dist/services/compact/index.d.ts",
      "default": "./dist/services/compact/index.js"
    },
    "./review": {
      "types": "./dist/review/review-gate.d.ts",
      "default": "./dist/review/review-gate.js"
    },
    "./worktree": {
      "types": "./dist/execution/workspace/worktree-manager.d.ts",
      "default": "./dist/execution/workspace/worktree-manager.js"
    },
    "./github-auth": {
      "types": "./dist/integration/github-app-auth.d.ts",
      "default": "./dist/integration/github-app-auth.js"
    },
    "./errors": {
      "types": "./dist/shared/errors.d.ts",
      "default": "./dist/shared/errors.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "test": "find tests -name '*.test.ts' -not -path 'tests/staging/*' -print0 | xargs -0 node --import tsx --experimental-test-module-mocks --test",
    "test:ts": "find tests -name '*.test.ts' -not -path 'tests/staging/*' -print0 | xargs -0 node --import tsx --experimental-test-module-mocks --test",
    "test:cjs": "node --test tests/**/*.test.cjs",
    "test:all": "node --test tests/**/*.test.cjs && node --import tsx --test tests/**/*.test.ts",
    "test:integration": "node --import tsx --test tests/integration/*.test.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "setup": "node --import tsx src/setup/cli.ts"
  },
  "bin": {
    "orch-setup": "./dist/setup/cli.js"
  },
  "keywords": [
    "orchestration",
    "agents",
    "sparc",
    "claude-flow",
    "autonomous-development"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.19.15",
    "eslint": "^9.22.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.27.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.86",
    "cloudflared": "^0.7.1",
    "commander": "^14.0.3",
    "fastify": "^5.8.2",
    "yaml": "^2.8.3"
  }
}
